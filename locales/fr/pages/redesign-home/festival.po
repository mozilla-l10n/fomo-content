msgid "Sometimes the best discoveries happen between sessions."
msgstr "Les meilleures découvertes ont parfois lieu entre deux sessions."

msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.right_column.172a43b4-1e5d-4d35-b1b4-4a60db9c2873.image.alt_text"
msgid "Pariticipants in motion going up and down stairs at Poble Espanyol during Mozilla Fesitval 2025"
msgstr "Des participants se déplacent en montant et descendant les escaliers du Poble Espanyol lors du Mozilla Festival 2025"

