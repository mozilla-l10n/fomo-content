msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.left_column.9d29fdb7-8e08-4a14-a10b-1f21335e4bc9.title"
msgid "We’re painting our vision together."
msgstr "Nous élaborons notre vision ensemble."

msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.left_column.9d29fdb7-8e08-4a14-a10b-1f21335e4bc9.image.alt_text"
msgid "An artist wearing a pink shirt sits in on the ground in front a painted mural they are working on"
msgstr "Un·e artiste portant une chemise rose est assis·e au sol devant une fresque en cours de réalisation"

msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.right_column.4cedd518-2cbc-444c-a5f8-a76ac50bdffd.title"
msgid "Delight in the unexpected. Technology. Art. Even fashion."
msgstr "Savourez la surprise : technologie, art et même la mode."

msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.right_column.4cedd518-2cbc-444c-a5f8-a76ac50bdffd.image.alt_text"
