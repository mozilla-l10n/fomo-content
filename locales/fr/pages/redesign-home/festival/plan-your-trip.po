msgid "Catalonia La Maquinista"
msgstr "Catalonia La Maquinista"

msgctxt "body.fe61425d-e623-40e3-99af-a02f16cf8f55.cards.99a6617a-affc-4d3a-9691-c90ab81fa019.cta_link.label"
msgid "Book now"
msgstr ""

msgctxt "body.fe61425d-e623-40e3-99af-a02f16cf8f55.cards.192f3d4e-1429-46b8-871b-93f31633174e.label"
msgid "15 minutes by Metro - 10% off with code CATALONIABCN"
msgstr "15 minutes en métro - 10 % de réduction avec le code CATALONIABCN"

msgctxt "body.fe61425d-e623-40e3-99af-a02f16cf8f55.cards.192f3d4e-1429-46b8-871b-93f31633174e.headline"
msgid "Catalonia Atenas"
msgstr "Catalonia Atenas"

msgctxt "body.fe61425d-e623-40e3-99af-a02f16cf8f55.cards.192f3d4e-1429-46b8-871b-93f31633174e.image.alt_text"
