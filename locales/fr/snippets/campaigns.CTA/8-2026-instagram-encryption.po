msgctxt "header"
msgid "Sign the petition to keep encryption for Instagram messages"
msgstr "Signez la pétition pour maintenir le chiffrement des messages Instagram"

msgctxt "description"
msgid "If enough people sign, we can protect privacy on Instagram."
msgstr "Si suffisamment de personnes signent, nous pourrons protéger la vie privée sur Instagram."

msgctxt "privacy_notice"
msgid "By signing you accept Mozilla handling your info as explained in this <a id=\"a1\">Privacy Notice</a>*"
msgstr "En signant, vous acceptez que Mozilla utilise vos informations conformément à <a id=\"a1\">cette politique de confidentialité</a>*"

msgctxt "donate_text"
msgid "Yes, I'll donate"
msgstr "Oui, je vais faire un don"

msgctxt "cta_button_text"
msgid "Add my name"
msgstr "Ajouter mon nom"
