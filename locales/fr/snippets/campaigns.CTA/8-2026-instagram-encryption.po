msgctxt "header"
msgid "Sign the petition to keep encryption for Instagram messages and make it the default."
msgstr ""

msgctxt "description"
msgid "If enough people sign, we can protect privacy on Instagram."
msgstr "Si suffisamment de personnes signent, nous pourrons protéger la confidentialité sur Instagram."

msgctxt "privacy_notice"
msgid "By signing you accept Mozilla handling your info as explained in this <a id=\"a1\">Privacy Notice</a>*"
msgstr "En signant cette pétition, vous acceptez que Mozilla traite vos informations conformément à cette <a id=\"a1\">Politique de confidentialité</a>*"

msgctxt "donate_text"
msgid "Yes, I'll donate"
msgstr "Je fais un don"

msgctxt "cta_button_text"
msgid "Add my name"
msgstr "Je signe la pétition"

