msgctxt "title"
msgid "Join our global movement for privacy rights."
msgstr "Dołącz do naszego globalnego ruchu na rzecz prawa do ochrony prywatności."

msgctxt "description"
msgid "Privacy for All is a global movement to secure privacy as a right for everyone, regardless of where they live."
msgstr "Privacy for All to globalna inicjatywa mająca na celu ochronę prawa do prywatności wszystkich obywateli, niezależnie od miejsca zamieszkania."

msgctxt "link_label"
msgid "Demand Privacy for All"
msgstr "Żądaj prywatności dla wszystkich"

