msgctxt "header"
msgid "Sign the petition to keep encryption for Instagram messages and make it the default."
msgstr "Firma la petición para mantener el cifrado de los mensajes de Instagram y que sea la opción predeterminada."

msgctxt "description"
msgid "If enough people sign, we can protect privacy on Instagram."
msgstr "Si suficientes personas firman, podemos proteger la privacidad en Instagram."

msgctxt "privacy_notice"
msgid "By signing you accept Mozilla handling your info as explained in this <a id=\"a1\">Privacy Notice</a>*"
msgstr "Al firmar, aceptas que Mozilla maneje tu información como se explica en esta <a id=\"a1\">Política de privacidad</a>*"

msgctxt "donate_text"
msgid "Yes, I'll donate"
msgstr "Sí, voy a donar"

msgctxt "cta_button_text"
msgid "Add my name"
msgstr "Añadan mi nombre"

#~ msgctxt "header"
#~ msgid "Sign the petition to keep encryption for Instagram messages"
#~ msgstr "Firma la petición para mantener el cifrado en los mensajes de Instagram"
