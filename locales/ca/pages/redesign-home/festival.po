msgstr "Un artista amb una camisa rosa assegut a terra davant d'un mural pintat en el qual està treballant"

msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.right_column.4cedd518-2cbc-444c-a5f8-a76ac50bdffd.title"
msgid "Delight in the unexpected. Technology. Art. Even fashion."
msgstr "Plaer en allò inesperat. Tecnologia. Art. Fins i tot moda."

msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.right_column.4cedd518-2cbc-444c-a5f8-a76ac50bdffd.image.alt_text"
