msgstr "Persones somrient i aixecant les mans en un auditori d'un espai d'esdeveniments amb sostre transparent"

msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.left_column.9d29fdb7-8e08-4a14-a10b-1f21335e4bc9.title"
msgid "We’re painting our vision together."
msgstr "Estem traçant la nostra visió junts."

msgctxt "body.79c80884-883e-4948-aad0-f0c99858f80c.left_column.9d29fdb7-8e08-4a14-a10b-1f21335e4bc9.image.alt_text"
