msgctxt "header"
msgid "Sign the petition to keep encryption for Instagram messages and make it the default."
msgstr ""

msgctxt "description"
msgid "If enough people sign, we can protect privacy on Instagram."
msgstr "Wenn genügend Menschen mitmachen, können wir den Datenschutz auf Instagram erhöhen."

msgctxt "privacy_notice"
msgid "By signing you accept Mozilla handling your info as explained in this <a id=\"a1\">Privacy Notice</a>*"
msgstr "Mit Ihrer Unterschrift stimmen Sie zu, dass Mozilla Ihre Daten wie in diesem <a id=\"a1\">Datenschutzhinweis</a> angegeben verwendet*"

msgctxt "donate_text"
msgid "Yes, I'll donate"
msgstr "Ja, ich spende gern"

msgctxt "cta_button_text"
msgid "Add my name"
msgstr "Ja, ich mache mit"
