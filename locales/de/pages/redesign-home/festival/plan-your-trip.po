msgctxt "body.9c9d3509-753f-4983-9311-31faa2ccb2c4.title"
msgid "Frequently Asked Questions"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.232b4a98-70ff-4238-a85e-c3715dc19b1d.title"
msgid "Do I need travel insurance?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.232b4a98-70ff-4238-a85e-c3715dc19b1d.content.7ecce94c-7eef-4cd8-a273-86cba078eaa3"
msgid "Though travel insurance is not a requirement to enter Spain, we do strongly recommend it in case of medical emergencies or trip cancellations."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.0021334f-ab4a-4226-be10-c71c6f51f7bd.title"
msgid "What's the weather like in late October?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.0021334f-ab4a-4226-be10-c71c6f51f7bd.content.e43f8e65-8f3a-427b-954e-fb123a1b29fd"
msgid ""
"Weather in Barcelona in late October is typically mild. You can expect daytime temperatures of 15-22 ℃ / 59-72 ℉. It will be cooler in the evenings and some rainfall is possible. Be sure to pack "
"layers and a light waterproof jacket."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.eb2c2e3b-cc3b-4545-adbd-4e835184b8e0.title"
msgid "What's the time zone?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.eb2c2e3b-cc3b-4545-adbd-4e835184b8e0.content.676fabd0-d418-4f29-b29f-b3b5737a0f8b"
msgid "Barcelona is in the Central European Time zone (CET, UTC +1). Daylight savings ends Sunday, October 25th, right before MozFest. Clocks will go back one hour."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.b036cbed-d010-439b-858c-062f8e93e078.title"
msgid "What currency is used?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.b036cbed-d010-439b-858c-062f8e93e078.content.20eb20a1-c917-45f2-9ebe-7e239df08a0e"
msgid ""
"Like the rest of the European Union, the local currency is the Euro (€). Major credit cards are widely accepted and contactless payment is the norm. ATMs are frequently available. Tipping is "
"appreciated but not expected."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.05263a79-c49a-45ab-ba95-c173e0b0af00.title"
msgid "What languages are spoken?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.05263a79-c49a-45ab-ba95-c173e0b0af00.content.eb969eb8-5cd7-471f-9004-8e750e6c0736"
msgid ""
"The city of Barcelona is located in Catalonia, an autonomous region of Spain. Catalan and Spanish (Castilian) are the official languages though English is widely spoken in hotels, restaurants, and "
"tourist areas, though not everywhere. A few words and phrases in Spanish or Catalan go a long way toward being a respectful visitor."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.e9a2ca7a-e97a-428e-90bb-51c8ac4f02c6.title"
msgid "Is the tap water safe to drink?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.e9a2ca7a-e97a-428e-90bb-51c8ac4f02c6.content.bd295dc1-6525-44df-a090-4b8713db503b"
msgid "Yes. The tap water in Barcelona is safe and meets EU drinking water standards."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.71cebe38-0f9c-45ca-814f-62c5c49c3112.title"
msgid "What plugs do I need?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.71cebe38-0f9c-45ca-814f-62c5c49c3112.content.27c957a5-6cdb-4f21-b642-6db4addf9eb0"
msgid "Spain uses Type C and Type F plugs (the kind with two round pins), 230 V / 50Hz."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.e56062df-87cd-4420-b873-58adeea157d4.title"
msgid "Should I book my flight before my visa is approved?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.e56062df-87cd-4420-b873-58adeea157d4.content.51198b69-3072-4629-8220-27afac954166"
msgid ""
"If you need to apply for a visa, you may be asked to show proof of accommodations and a return flight. We recommend booking refundable flights and accommodation until you have your visa in hand."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.02cf8fae-7dfa-4d6d-90fc-defcf6476d38.title"
msgid "Are vaccinations required?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.02cf8fae-7dfa-4d6d-90fc-defcf6476d38.content.a57a25f0-1fcc-4119-9ed1-90f24de254ec"
msgid ""
"No, there aren’t any vaccinations required to enter Spain from most countries. We advise you consult a medical professional or check your local health authority website if you have specific "
"concerns."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.7db67453-b556-406a-bac2-fa30c9cdab94.title"
msgid "What's the public emergency number in Spain?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.7db67453-b556-406a-bac2-fa30c9cdab94.content.59e41dda-c353-4938-b887-7f48dc95392d"
msgid "The primary emergency number throughout the EU is 112. This number can be used for police, fire, or medical emergencies."
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.a29b1176-2267-4f01-b657-a35919c62c96.title"
msgid "Who do I contact with questions?"
msgstr ""

msgctxt "body.9b268a05-ae9f-4a3b-b902-bb5a46b6bd8b.accordion_items.a29b1176-2267-4f01-b657-a35919c62c96.content.d05cba69-2ee9-4ac1-9be3-d3f37dae6fcf"
msgid "Feel free to reach out to us at <a id=\"a1\">festival@mozillafoundation.org</a> for questions about participation, travel, accessibility, dietary needs, and anything else. We’re here to help."
msgstr ""
