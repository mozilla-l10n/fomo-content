msgctxt "body.fd93bc6e-e7e2-4298-9eb8-40f267a1db20.cards.cf15d6fb-3bb9-4ad3-b975-140cdfb9fba7.cta_link.6463341c-3caa-4361-8e0d-2acf40e95924.label"
