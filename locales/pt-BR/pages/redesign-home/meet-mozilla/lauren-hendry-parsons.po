msgctxt "seo_title"
msgid "Lauren Hendry Parsons - Director, Communications | Mozilla Foundation"
msgstr "Lauren Hendry Parsons - Diretora de Comunicações | Fundação Mozilla"

msgctxt "search_description"
msgid "Discover the global leaders behind Mozilla Foundation, working at the intersection of technology, ethics, and equity to shape a better digital future."
msgstr "Conheça os líderes globais por trás da Fundação Mozilla que atuam na junção entre tecnologia, ética e equidade em busca de um futuro digital melhor."

msgctxt "title"
msgid "Lauren Hendry Parsons"
msgstr "Lauren Hendry Parsons"

