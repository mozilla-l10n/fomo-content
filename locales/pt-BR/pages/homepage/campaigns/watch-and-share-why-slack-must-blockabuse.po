msgctxt "search_description"
msgid "Slack fails to protect its users from harassment and abusive messages. Hear why Mozilla is calling for a block feature."
msgstr "O Slack falha em proteger seus usuários contra assédio e mensagens abusivas. Ouça porque a Mozilla está pressionando para ter um recurso de bloqueio."

msgctxt "title"
msgid "Watch and share: Why Slack must #BlockAbuse"
msgstr "Assista e compartilhe: Por que o Slack deve #BlockAbuse"

msgctxt "body.ce4013f0-8b24-4600-ae03-f5a369d94900.label"
msgid "Share this video on Twitter"
msgstr "Compartilhe este vídeo no Twitter"

msgctxt "body.d8fce5c2-073c-453a-95f4-1eda1496b25a.label"
msgid "Share this video on Facebook"
msgstr "Compartilhe este vídeo no Facebook"

msgctxt "body.a2a6d11e-53cd-46a3-aca9-44f0b244ac24"
msgid "Have a Slack story of your own to share?"
msgstr "Tem uma história própria do Slack para compartilhar?"

msgctxt "body.a2a6d11e-53cd-46a3-aca9-44f0b244ac24"
msgid "Please share anonymously (or not) to help demonstrate how important a block function on Slack is."
msgstr "Compartilhe anonimamente (ou não) para ajudar a demonstrar como é importante ter uma função de bloqueio no Slack."
